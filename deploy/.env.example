# Copy to deploy/.env and adjust for your environment.

# Platform control plane (PostgreSQL)
PLATFORM_DATABASE_URL=postgresql+psycopg://hermes:hermes@127.0.0.1:5432/hermes_platform

# Upstream LLM gateway (new-api)
NEW_API_BASE_URL=https://your-new-api.example.com
NEW_API_ADMIN_TOKEN=

# auto = provision user+key via Admin API; manual = pending_bind until bind-key
UPSTREAM_PROVISIONER=manual

# Optional embedding API for RAG (falls back to keyword search offline)
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Cookie settings (platform-api + web_chat share hermes_session)
PLATFORM_COOKIE_TTL_SECONDS=604800
PLATFORM_COOKIE_SECURE=false

# Login brute-force guard (in-process sliding window; no Redis required for MVP)
PLATFORM_LOGIN_MAX_FAILURES=5
PLATFORM_LOGIN_WINDOW_SECONDS=300

# Ports
PLATFORM_API_PORT=8700

# KeyVault master secret (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
HERMES_WEB_KEY_VAULT_SECRET=
